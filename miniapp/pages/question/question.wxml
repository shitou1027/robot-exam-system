<!-- 答题页面 -->
<view class="container">
  <!-- 顶部进度栏 -->
  <view class="header">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%"></view>
    </view>
    <text class="progress-text">{{currentIndex + 1}}/{{questions.length}}</text>
  </view>

  <!-- 题目区域 -->
  <view class="question-card" wx:if="{{currentQuestion}}">
    <!-- 题目信息 -->
    <view class="question-meta">
      <text class="level-tag">{{currentQuestion.level}}级</text>
      <text class="type-tag">{{typeMap[currentQuestion.type]}}</text>
      <text class="year-tag">{{currentQuestion.year}}年</text>
    </view>

    <!-- 题目内容 -->
    <view class="question-content">
      <text class="question-text">{{currentQuestion.content}}</text>
    </view>

    <!-- 选项列表 -->
    <view class="options-list">
      <view 
        class="option-item {{selectedAnswer === item.key ? 'selected' : ''}} {{showResult && item.key === currentQuestion.answer ? 'correct' : ''}} {{showResult && selectedAnswer === item.key && selectedAnswer !== currentQuestion.answer ? 'wrong' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectOption"
      >
        <text class="option-key">{{item.key}}</text>
        <text class="option-content">{{item.content}}</text>
        <text class="option-icon" wx:if="{{showResult && item.key === currentQuestion.answer}}">✓</text>
        <text class="option-icon wrong" wx:if="{{showResult && selectedAnswer === item.key && selectedAnswer !== currentQuestion.answer}}">✗</text>
      </view>
    </view>

    <!-- 答案解析 -->
    <view class="explanation-card" wx:if="{{showResult}}">
      <view class="explanation-header">
        <text class="explanation-title">答案解析</text>
        <text class="answer-text">正确答案：{{currentQuestion.answer}}</text>
      </view>
      <text class="explanation-content">{{currentQuestion.explanation || '暂无解析'}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="footer">
    <view class="footer-btn favorite" bindtap="toggleFavorite">
      <text class="btn-icon">{{isFavorited ? '⭐' : '☆'}}</text>
      <text class="btn-text">收藏</text>
    </view>
    
    <view class="footer-btn {{showResult ? 'disabled' : ''}}" bindtap="submitAnswer" wx:if="{{!showResult}}">
      <text class="btn-text">确认答案</text>
    </view>
    
    <view class="footer-btn primary" bindtap="nextQuestion" wx:if="{{showResult}}">
      <text class="btn-text">{{isLast ? '完成' : '下一题'}}</text>
    </view>
  </view>
</view>

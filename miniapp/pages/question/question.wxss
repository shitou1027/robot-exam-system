/* 答题页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 顶部进度栏 */
.header {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #E8F5E9;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
  min-width: 80rpx;
  text-align: right;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}

.question-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.level-tag, .type-tag, .year-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.level-tag {
  background: #E3F2FD;
  color: #1976D2;
}

.type-tag {
  background: #F3E5F5;
  color: #7B1FA2;
}

.year-tag {
  background: #FFF3E0;
  color: #E65100;
}

.question-content {
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 34rpx;
  color: #333;
  line-height: 1.6;
  font-weight: 500;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.option-item:active {
  background: #e9ecef;
}

.option-item.selected {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.option-item.correct {
  background: #C8E6C9;
  border-color: #4CAF50;
}

.option-item.wrong {
  background: #FFCDD2;
  border-color: #F44336;
}

.option-key {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #fff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  margin-top: 4rpx;
}

.option-item.selected .option-key,
.option-item.correct .option-key {
  background: #4CAF50;
  color: #fff;
}

.option-item.wrong .option-key {
  background: #F44336;
  color: #fff;
}

.option-content {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-all;
  white-space: normal;
  padding-top: 6rpx;
}

.option-icon {
  font-size: 36rpx;
  color: #4CAF50;
  margin-left: 10rpx;
}

.option-icon.wrong {
  color: #F44336;
}

/* 解析卡片 */
.explanation-card {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
  border-left: 8rpx solid #FFC107;
}

.explanation-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.explanation-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #F57C00;
}

.answer-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.explanation-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
}

.footer-btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8F5E9;
  border-radius: 45rpx;
  gap: 10rpx;
}

.footer-btn.favorite {
  flex: 0 0 180rpx;
}

.footer-btn.primary {
  background: #4CAF50;
}

.footer-btn.disabled {
  opacity: 0.5;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: 500;
}

.footer-btn.primary .btn-text {
  color: #fff;
}

<!-- 个人中心 -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '点击登录'}}</text>
      <text class="level-text">正在学习：{{currentLevel}}级</text>
    </view>
    <view class="login-btn" wx:if="{{!isLogin}}" bindtap="doLogin">登录</view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.totalQuestions}}</text>
      <text class="stat-label">总题数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.correctRate}}%</text>
      <text class="stat-label">正确率</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.streak}}</text>
      <text class="stat-label">连续天数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalExams}}</text>
      <text class="stat-label">模拟考</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="viewHistory">
      <text class="menu-icon">📝</text>
      <text class="menu-text">考试记录</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="viewWrong">
      <text class="menu-icon">❌</text>
      <text class="menu-text">错题本</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="viewFavorite">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="viewProgress">
      <text class="menu-icon">📊</text>
      <text class="menu-text">学习进度</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="chooseLevel">
      <text class="menu-icon">🎯</text>
      <text class="menu-text">切换等级</text>
      <text class="menu-extra">{{currentLevel}}级 ></text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>

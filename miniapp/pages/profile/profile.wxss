/* 个人中心样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #fff;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.level-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.login-btn {
  padding: 16rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  background: #f0f0f0;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.menu-extra {
  font-size: 26rpx;
  color: #999;
}

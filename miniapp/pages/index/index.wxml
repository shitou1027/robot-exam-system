<!-- 首页 -->
<view class="container">
  <!-- 欢迎区域 -->
  <view class="welcome-section">
    <text class="title">机器人等级考试</text>
    <text class="subtitle">青少年技术等级考试刷题平台</text>
  </view>

  <!-- 等级选择 -->
  <view class="level-section">
    <text class="section-title">选择等级</text>
    <view class="level-grid">
      <view 
        class="level-item {{currentLevel === item ? 'active' : ''}}"
        wx:for="[1,2,3,4,5,6,7,8]"
        wx:key="*this"
        data-level="{{item}}"
        bindtap="selectLevel"
      >
        <text class="level-num">{{item}}级</text>
        <text class="level-name">{{levelNames[item-1]}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="action-card" bindtap="startPractice">
      <text class="action-icon">📚</text>
      <text class="action-title">顺序练习</text>
      <text class="action-desc">按顺序刷题</text>
    </view>
    <view class="action-card" bindtap="startMockExam">
      <text class="action-icon">📝</text>
      <text class="action-title">模拟考试</text>
      <text class="action-desc">30题/60分钟</text>
    </view>
    <view class="action-card" bindtap="continueWrong">
      <text class="action-icon">❌</text>
      <text class="action-title">错题重做</text>
      <text class="action-desc">巩固薄弱点</text>
    </view>
    <view class="action-card" bindtap="viewFavorites">
      <text class="action-icon">⭐</text>
      <text class="action-title">收藏题目</text>
      <text class="action-desc">查看收藏</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-section">
    <text class="section-title">学习统计</text>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.totalQuestions}}</text>
        <text class="stat-label">已做题</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.correctRate}}%</text>
        <text class="stat-label">正确率</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.streak}}</text>
        <text class="stat-label">连续天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.totalExams}}</text>
        <text class="stat-label">模拟考</text>
      </view>
    </view>
  </view>
</view>

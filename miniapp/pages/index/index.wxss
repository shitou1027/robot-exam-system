/* 首页样式 */
.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 80rpx 40rpx 60rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* 等级卡片 */
.level-card {
  background: #fff;
  margin: -30rpx 30rpx 30rpx;
  padding: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(76,175,80,0.15);
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-title {
  font-size: 28rpx;
  color: #666;
}

.level-badge {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.level-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.level-scroll {
  white-space: nowrap;
}

.level-list {
  display: inline-flex;
  gap: 16rpx;
}

.level-btn {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #666;
}

.level-btn.active {
  background: #E8F5E9;
  color: #4CAF50;
  font-weight: bold;
}

/* 区块 */
.section {
  padding: 0 30rpx 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 功能网格 */
.action-grid {
  display: flex;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  background: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  text-align: center;
}

.action-icon-circle {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  font-size: 48rpx;
  margin: 0 auto 16rpx;
}

.action-icon-circle.practice {
  background: linear-gradient(135deg, #42A5F5, #64B5F6);
}

.action-icon-circle.exam {
  background: linear-gradient(135deg, #FF7043, #FF8A65);
}

.action-icon-small {
  font-size: 40rpx;
  display: block;
  margin-bottom: 12rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.action-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-item.small {
  padding: 30rpx 20rpx;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  margin: 0 30rpx 30rpx;
  padding: 40rpx;
  border-radius: 20rpx;
}

.stat-row {
  display: flex;
  gap: 20rpx;
}

.stat-row:last-child {
  margin-top: 24rpx;
}

.stat-box {
  flex: 1;
  text-align: center;
  padding: 30rpx 20rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stat-text {
  display: block;
  font-size: 26rpx;
  color: #999;
}

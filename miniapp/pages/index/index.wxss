/* 首页样式 */
.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #43A047 0%, #66BB6A 50%, #81C784 100%);
  padding: 100rpx 40rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.header::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 1;
}

/* 等级卡片 */
.level-card {
  background: #fff;
  margin: -50rpx 30rpx 30rpx;
  padding: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(76,175,80,0.2);
  position: relative;
  z-index: 10;
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.level-title {
  font-size: 28rpx;
  color: #666;
}

.level-badge {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.level-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.level-scroll {
  white-space: nowrap;
}

.level-list {
  display: inline-flex;
  gap: 16rpx;
}

.level-btn {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.level-btn.active {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.4);
}

/* 区块 */
.section {
  padding: 0 30rpx 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 功能网格 */
.action-grid {
  display: flex;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  background: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.action-icon-circle {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  font-size: 48rpx;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.action-icon-circle.practice {
  background: linear-gradient(135deg, #2196F3, #42A5F5);
  box-shadow: 0 8rpx 24rpx rgba(33,150,243,0.3);
}

.action-icon-circle.exam {
  background: linear-gradient(135deg, #FF5722, #FF7043);
  box-shadow: 0 8rpx 24rpx rgba(255,87,34,0.3);
}

.action-icon-small {
  font-size: 44rpx;
  display: block;
  margin-bottom: 16rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.action-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.action-item.small {
  padding: 30rpx 20rpx;
  background: linear-gradient(180deg, #fff 0%, #fafafa 100%);
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
  margin: 0 30rpx 40rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.stat-row {
  display: flex;
  gap: 24rpx;
}

.stat-row:last-child {
  margin-top: 24rpx;
}

.stat-box {
  flex: 1;
  text-align: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.02);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.stat-text {
  display: block;
  font-size: 26rpx;
  color: #999;
}

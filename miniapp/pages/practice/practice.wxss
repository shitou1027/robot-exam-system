/* 练习页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 等级标签 */
.level-tabs {
  background: #fff;
  padding: 20rpx;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: #fff;
}

/* 功能卡片 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 20rpx;
}

.feature-card {
  width: calc(50% - 10rpx);
  background: #fff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.feature-icon {
  display: block;
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.feature-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 区块 */
.section {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.more {
  font-size: 26rpx;
  color: #4CAF50;
}

/* 历年真题 */
.year-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.year-card {
  width: calc(25% - 15rpx);
  background: #f8f9fa;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.year-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #4CAF50;
}

.year-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.year-count {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}

/* 知识点标签 */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #E8F5E9;
  color: #4CAF50;
  border-radius: 30rpx;
  font-size: 26rpx;
}
